# Railway cria PORT automaticamente. Não precisa preencher PORT.
SECRET_KEY=troque-por-uma-chave-grande-e-aleatoria

# Usado somente se o banco estiver vazio, por exemplo em um Volume novo.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=123456
DEFAULT_ADMIN_NAME=Administrador

# Opcional: caminho manual para o SQLite. Normalmente deixe vazio no Railway.
# DB_PATH=/app/dados.db
